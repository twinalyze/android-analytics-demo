<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".fragment.CartFragment">

        <LinearLayout
            android:id="@+id/ll_toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="?actionBarSize">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cart"
            android:layout_centerVertical="true"
            android:textSize="18sp"
            android:layout_toStartOf="@+id/btn_close"
            android:fontFamily="@font/sf_pro_semibold"
            android:layout_marginHorizontal="@dimen/_5sdp"
            android:textColor="@color/text_color"/>

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_close"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginHorizontal="@dimen/_10sdp"/>


    </RelativeLayout>

    <View
        android:id="@+id/view1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"/>
</LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/ll_toolbar"
            android:layout_above="@+id/ll_bottom"
            android:background="@android:color/white">

            <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Items"
                android:textStyle="bold"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColor="@color/text_color"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/txtAddMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add more"
                android:textSize="14sp"
                android:fontFamily="@font/sf_pro_medium"
                android:textColor="@color/selected_color"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:overScrollMode="never"
            android:scrollbars="none" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Coupon"
            android:fontFamily="@font/sf_pro_semibold"
            android:textColor="@color/text_color"
            android:textSize="18sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginVertical="@dimen/_10sdp"
            android:background="@drawable/bg_card_border"
            android:backgroundTint="#F7F7F7"
            android:padding="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add coupon code"
                    android:textSize="16sp"
                    android:layout_toStartOf="@+id/txtApply"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/unselected_color" />

                <TextView
                    android:id="@+id/txtApply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apply"
                    android:textSize="16sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:textColor="@color/text_color" />

            </RelativeLayout>


        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bill Details"
            android:fontFamily="@font/sf_pro_semibold"
            android:textColor="@color/text_color"
            android:textSize="18sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginVertical="@dimen/_10sdp"
            android:background="@drawable/bg_card_border"
            android:backgroundTint="#F7F7F7"
            android:padding="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Subtotal"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtRs3"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/unselected_color" />

                <TextView
                    android:id="@+id/txtRs3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹"
                    android:textSize="14sp"
                    android:layout_marginEnd="@dimen/_3sdp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/txtSubTotal"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/text_color" />

                <TextView
                    android:id="@+id/txtSubTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="599"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/text_color" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/_5sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Delivery Fee"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtFree"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/unselected_color" />

                <TextView
                    android:id="@+id/txtFree"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Free"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textColor="#41BB47" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/_5sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Discount"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtRs4"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/unselected_color" />

                <TextView
                    android:id="@+id/txtRs4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹"
                    android:textSize="14sp"
                    android:layout_marginEnd="@dimen/_3sdp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/txtDiscount"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/text_color" />

                <TextView
                    android:id="@+id/txtDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:text="80"
                    android:textColor="@color/text_color"
                    android:textSize="14sp" />

            </RelativeLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="6dp"
                android:background="#E0E0E0" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/_5sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtRs5"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/text_color" />

                <TextView
                    android:id="@+id/txtRs5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹"
                    android:textSize="14sp"
                    android:layout_marginEnd="@dimen/_3sdp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/txtTotal"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:textColor="@color/text_color" />

                <TextView
                    android:id="@+id/txtTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-519"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:textColor="@color/text_color" />

            </RelativeLayout>


        </LinearLayout>




    </LinearLayout>

        </ScrollView>

        <LinearLayout
            android:id="@+id/ll_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentBottom="true"
            android:padding="12dp">

            <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:layout_toStartOf="@+id/layoutPlaceOrder">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Amount"
                    android:textSize="12sp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/unselected_color" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="@dimen/_5sdp"
                    android:layout_gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtRs6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:textSize="16sp"
                        android:layout_marginEnd="@dimen/_3sdp"
                        android:layout_toStartOf="@+id/txtSubTotal"
                        android:fontFamily="@font/sf_pro_semibold"
                        android:textColor="@color/text_color" />

                    <TextView
                        android:id="@+id/txtTotalAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="599"
                        android:textSize="16sp"
                        android:fontFamily="@font/sf_pro_semibold"
                        android:textColor="@color/text_color" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPlaceOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_centerVertical="true"
                android:layout_marginVertical="@dimen/_5sdp"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/rounded_corner"
                android:paddingHorizontal="10dp">
                <TextView
                    android:id="@+id/txtPlaceOrder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Place Order"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:padding="@dimen/_10sdp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textColor="@color/white" />

            </LinearLayout>

        </RelativeLayout>


        </LinearLayout>

</RelativeLayout>