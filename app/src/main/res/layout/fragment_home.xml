<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragment.HomeFragment"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Address & Cart Row -->

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_55sdp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <!-- Location Icon -->
            <ImageView
                android:id="@+id/imgLocation"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_location"
                android:layout_centerVertical="true"/>

            <!-- Address Block -->
            <LinearLayout
                android:id="@+id/layoutAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="@dimen/_8sdp"
                android:layout_toEndOf="@id/imgLocation"
                android:layout_toStartOf="@id/rl_cart"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="@dimen/_3sdp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtDeliverTo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deliver to"
                        android:textSize="@dimen/_10sdp"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/unselected_color" />

                    <ImageView
                        android:id="@+id/btn_drop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_below_arrow"
                        android:layout_gravity="center"
                        android:layout_marginHorizontal="@dimen/_5sdp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/txtAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="3517 W. Gray St. Utica, Pennsylvania 57867"
                    android:textSize="@dimen/_12sdp"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textColor="#333333" />
            </LinearLayout>

            <!-- Cart with Badge -->
            <RelativeLayout
                android:id="@+id/rl_cart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <ImageView
                    android:id="@+id/imgCart"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:src="@drawable/ic_cart"
                    android:layout_gravity="center"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="@dimen/_10sdp"/>

                <!-- Badge Count -->
                <TextView
                    android:id="@+id/txtCartBadge"
                    android:layout_width="@dimen/_12sdp"
                    android:layout_height="@dimen/_12sdp"
                    android:layout_alignTop="@id/imgCart"
                    android:layout_alignEnd="@id/imgCart"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_badge_circle"
                    android:fontFamily="@font/sf_pro_bold"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:translationX="15dp"
                    android:translationY="-2dp" />
            </RelativeLayout>

        </RelativeLayout>

        <View
            android:id="@+id/indicator_home"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:visibility="visible" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="@dimen/_10sdp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >


                <!-- Search Box -->
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:background="@drawable/search_round_button"
                    android:hint="Search restaurant and food"
                    android:padding="12dp"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:paddingStart="@dimen/_15sdp"
                    android:layout_gravity="center"
                    android:textSize="16sp"
                    android:textColor="@color/text_color"
                    android:textColorHint="@color/unselected_color"
                    android:fontFamily="@font/sf_pro_regular"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Category"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/sf_pro_bold"
                    android:textColor="@color/text_color"
                    android:textSize="18sp"/>

                <!-- Category Horizontal Scroll -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none"/>


                <androidx.cardview.widget.CardView
                    android:id="@+id/flat_banner"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginVertical="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Background image -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/section1" />

                        <!--&lt;!&ndash; Foreground content &ndash;&gt;
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">

                            &lt;!&ndash; Left Texts &ndash;&gt;
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_centerVertical="true"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/txtOfferTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Flat 20% OFF on\nfirst order"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/sf_pro_bold"
                                    android:textColor="#673AB7"
                                    android:textSize="16sp" />

                                <TextView
                                    android:id="@+id/txtOfferSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
