<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".OrdersDetailsActivity">

    <LinearLayout
        android:id="@+id/ll_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?actionBarSize">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_back"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"/>

            <TextView
                android:id="@+id/txtTitleOrderId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="£123456"
                android:layout_centerVertical="true"
                android:textSize="18sp"
                android:layout_toRightOf="@+id/btn_back"
                android:fontFamily="@font/sf_pro_semibold"
                android:layout_marginHorizontal="@dimen/_5sdp"
                android:textColor="@color/text_color"/>

        </RelativeLayout>

        <View
            android:id="@+id/view1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/ll_toolbar"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order Details"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColor="@color/text_color"
                android:textSize="18sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginVertical="@dimen/_10sdp"
            android:background="@drawable/bg_card_border"
            android:padding="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Order ID"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtOrderId"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/unselected_color" />

                <TextView
                    android:id="@+id/txtOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#123456"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/text_color" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtDateTime"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/unselected_color" />

                <TextView
                    android:id="@+id/txtDateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25 Sep 2025 at 10:30 pm"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/text_color" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtPending"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_regular"
                    android:textColor="@color/unselected_color" />

                <TextView
                    android:id="@+id/txtPending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:textColor="#E39F00" />

            </RelativeLayout>


        </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Item Details"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColor="@color/text_color"
                android:textSize="18sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginVertical="@dimen/_10sdp"
                android:background="@drawable/bg_card_border"
                android:padding="12dp">


                <!-- Restaurant Name -->

                <TextView
                    android:id="@+id/txtRestaurantName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pizza Planet"
                    android:textSize="16sp"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textColor="#000000" />


                <!-- Address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_location_restaurants"
                        android:layout_marginEnd="4dp"
                        android:layout_gravity="center"
                        app:tint="#7A7A7A" />

                    <TextView
                        android:id="@+id/txtAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Near Race Course, Surat"
                        android:textSize="12sp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/unselected_color" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:background="#E0E0E0" />

                <!-- Food Items -->
                <LinearLayout
                    android:id="@+id/layoutFoodItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1x Margherita Cheese Burst"
                            android:textSize="14sp"
                            android:layout_toStartOf="@+id/txtRs1"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/sf_pro_medium"
                            android:textColor="@color/text_color" />

                        <TextView
                            android:id="@+id/txtRs1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textSize="14sp"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@+id/txtPrice1"
                            android:fontFamily="@font/sf_pro_semibold"
                            android:textColor="@color/text_color" />

                        <TextView
                            android:id="@+id/txtPrice1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="299"
                            android:textSize="14sp"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/sf_pro_semibold"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:textColor="@color/text_color" />

                    </RelativeLayout>


                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:visibility="gone"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1x Spicy Veggie Delight"
                            android:textSize="14sp"
                            android:layout_toStartOf="@+id/txtRs2"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/sf_pro_medium"
                            android:textColor="@color/text_color" />

                        <TextView
                            android:id="@+id/txtRs2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textSize="14sp"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@+id/txtPrice2"
                            android:fontFamily="@font/sf_pro_semibold"
                            android:textColor="@color/text_color" />

                        <TextView
                            android:id="@+id/txtPrice2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="399"
                            android:textSize="14sp"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/sf_pro_semibold"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="@dimen/_10sdp"
                            android:textColor="@color/text_color" />

                    </RelativeLayout>


                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bill Details"
                android:fontFamily="@font/sf_pro_semibold"
                android:textColor="@color/text_color"
                android:textSize="18sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginVertical="@dimen/_10sdp"
                android:background="@drawable/bg_card_border"
                android:backgroundTint="#F7F7F7"
                android:padding="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Subtotal"
                        android:textSize="14sp"
                        android:layout_toStartOf="@+id/txtRs3"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/unselected_color" />

                    <TextView
                        android:id="@+id/txtRs3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:textSize="14sp"
                        android:layout_marginEnd="@dimen/_3sdp"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/txtSubTotal"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/text_color" />

                    <TextView
                        android:id="@+id/txtSubTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="599"
                        android:textSize="14sp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/text_color" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/_5sdp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Delivery Fee"
                        android:textSize="14sp"
                        android:layout_toStartOf="@+id/txtFree"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/unselected_color" />

                    <TextView
                        android:id="@+id/txtFree"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Free"
                        android:textSize="14sp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/sf_pro_medium"
                        android:textColor="#41BB47" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/_5sdp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Discount"
                        android:textSize="14sp"
                        android:layout_toStartOf="@+id/txtRs4"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/unselected_color" />

                    <TextView
                        android:id="@+id/txtRs4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:textSize="14sp"
                        android:layout_marginEnd="@dimen/_3sdp"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/txtDiscount"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/text_color" />

                    <TextView
                        android:id="@+id/txtDiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="80"
                        android:textSize="14sp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/text_color" />

                </RelativeLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:background="#E0E0E0" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/_5sdp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textSize="14sp"
                        android:layout_toStartOf="@+id/txtRs5"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/sf_pro_regular"
                        android:textColor="@color/text_color" />

                    <TextView
                        android:id="@+id/txtRs5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:textSize="14sp"
                        android:layout_marginEnd="@dimen/_3sdp"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/txtTotal"
                        android:fontFamily="@font/sf_pro_semibold"
                        android:textColor="@color/text_color" />

                    <TextView
                        android:id="@+id/txtTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-519"
                        android:textSize="14sp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/sf_pro_semibold"
                        android:textColor="@color/text_color" />

                </RelativeLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/btnCancelOrder"
                android:layout_width="match_parent"
                android:layout_height="43sp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="#E0E0E0"
                android:layout_weight="1"
                android:backgroundTint="#EF4444"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="@dimen/_5sdp">

                <TextView
                    android:id="@+id/txtCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="Cancel Order"
                    android:textSize="16sp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textColor="@color/white"/>
            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:id="@+id/btnComplete"
                android:layout_width="match_parent"
                android:layout_height="43sp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:layout_weight="1"
                app:strokeColor="#E0E0E0"
                android:backgroundTint="#29B85F"
                android:layout_marginTop="15dp"
                android:layout_marginStart="@dimen/_5sdp">

                <TextView
                    android:id="@+id/txtComplete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="Complete Order"
                    android:textSize="16sp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textColor="@color/white"/>
            </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>