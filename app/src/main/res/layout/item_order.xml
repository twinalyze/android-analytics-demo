<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_5sdp"
    android:background="@drawable/bg_card_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Date & Order ID -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="26 Sep 2025"
                android:textSize="14sp"
                android:layout_toStartOf="@+id/txtOrderId"
                android:layout_centerVertical="true"
                android:fontFamily="@font/sf_pro_regular"
                android:textColor="@color/unselected_color" />

            <TextView
                android:id="@+id/txtOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#123456"
                android:textSize="14sp"
                android:layout_toStartOf="@id/next_btn"
                android:layout_centerVertical="true"
                android:fontFamily="@font/sf_pro_regular"
                android:textColor="#525252" />

            <ImageView
                android:id="@+id/next_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/right_arrow"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginHorizontal="@dimen/_10sdp"/>

        </RelativeLayout>

        <!-- Restaurant Name -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtRestaurantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pizza Planet"
                android:textSize="16sp"
                android:layout_centerVertical="true"
                android:fontFamily="@font/sf_pro_medium"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_corner"
                android:backgroundTint="#FFF7DB"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:text="Pending"
                android:textSize="12sp"
                android:paddingVertical="3sp"
                android:paddingHorizontal="@dimen/_10sdp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:visibility="visible"
                android:textColor="#E39F00" />
        </RelativeLayout>

        <!-- Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location_restaurants"
                android:layout_marginEnd="4dp"
                android:layout_gravity="center"
                app:tint="#7A7A7A" />

            <TextView
                android:id="@+id/txtAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Near Race Course, Surat"
                android:textSize="12sp"
                android:layout_gravity="center"
                android:gravity="center"
                android:fontFamily="@font/sf_pro_regular"
                android:textColor="@color/unselected_color" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="#E0E0E0" />

        <!-- Food Items -->
        <LinearLayout
            android:id="@+id/layoutFoodItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1x Margherita Cheese Burst"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtRs1"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textColor="@color/text_color" />

                <TextView
                    android:id="@+id/txtRs1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/txtPrice1"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:textColor="@color/text_color" />

                <TextView
                    android:id="@+id/txtPrice1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="299"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:textColor="@color/text_color" />

            </RelativeLayout>


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1x Spicy Veggie Delight"
                    android:textSize="14sp"
                    android:layout_toStartOf="@+id/txtRs2"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textColor="@color/text_color" />

                <TextView
                    android:id="@+id/txtRs2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/txtPrice2"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:textColor="@color/text_color" />

                <TextView
                    android:id="@+id/txtPrice2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="399"
                    android:textSize="14sp"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/sf_pro_semibold"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="@dimen/_10sdp"
                    android:textColor="@color/text_color" />

            </RelativeLayout>


        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
